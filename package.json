{
  "name": "stellar-wallet-checker",
  "version": "2.0.0",
  "description": "Multi-wallet Stellar testnet manager with smart contract integration and real-time events",
  "type": "module",
  "author": "Frank Osakwe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankosakwe/stellar-wallet-checker.git"
  },
  "keywords": [
    "stellar",
    "blockchain",
    "wallet",
    "freighter",
    "xbull",
    "testnet",
    "xlm",
    "smart-contract",
    "soroban",
    "cryptocurrency"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@stellar/freighter-api": "^2.0.0",
    "stellar-sdk": "^11.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/user-event": "^14.5.1",
    "vitest": "^1.0.4",
    "jsdom": "^23.0.1",
    "@vitest/ui": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "prettier": "^3.1.1"
  }
}
